    "cors": "^2.8.5",
    "express": "^4.18.2",
    "form-data": "^4.0.6",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3",
    "pinia": "^2.1.0",
    "uuid": "^9.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "happy-dom": "^20.8.4",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
